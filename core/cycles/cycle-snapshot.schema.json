{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CycleSnapshot",
  "description": "Record of one institutional cycle. Cycles create operational continuity and observability.",
  "version": "0.1",
  "type": "object",
  "required": ["cycle_id", "started_at", "ended_at"],
  "properties": {
    "cycle_id":   { "type": "integer", "minimum": 1, "description": "Sequential cycle number" },
    "started_at": { "type": "string", "format": "date-time" },
    "ended_at":   { "type": "string", "format": "date-time" },
    "new_signal_ids": {
      "type": "array",
      "items": { "type": "string" },
      "default": [],
      "description": "Signals ingested during this cycle"
    },
    "updated_proceeding_ids": {
      "type": "array",
      "items": { "type": "string" },
      "default": [],
      "description": "Proceedings that received interventions"
    },
    "new_intervention_ids": {
      "type": "array",
      "items": { "type": "string" },
      "default": [],
      "description": "Interventions submitted during this cycle"
    },
    "resolved_obligation_ids": {
      "type": "array",
      "items": { "type": "string" },
      "default": [],
      "description": "Obligations resolved during this cycle"
    },
    "settled_proceeding_ids": {
      "type": "array",
      "items": { "type": "string" },
      "default": [],
      "description": "Proceedings that reached settlement"
    },
    "agenda_summary": {
      "type": ["object", "null"],
      "properties": {
        "highest_priority": { "type": "array", "items": { "type": "string" } }
      },
      "description": "Snapshot of institutional attention at cycle end"
    },
    "institutional_notes": {
      "type": "array",
      "items": { "type": "string" },
      "default": [],
      "description": "Free-form notes about this cycle"
    }
  }
}
