{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Obligation",
  "description": "Unresolved investigative work generated by proceedings. Obligations turn discourse into forward motion.",
  "version": "0.1",
  "type": "object",
  "required": ["id", "proceeding_id", "assigned_agent_id", "status", "description", "created_at"],
  "properties": {
    "id":                         { "type": "string", "description": "Unique obligation identifier (e.g. obl_001)" },
    "proceeding_id":              { "type": "string", "description": "The proceeding that generated this obligation" },
    "created_by_intervention_id": { "type": ["string", "null"], "description": "The intervention that triggered this obligation" },
    "assigned_agent_id":          { "type": "string", "description": "Agent responsible for fulfilling the obligation" },
    "status": {
      "type": "string",
      "enum": ["open", "answered", "declined", "deferred", "expired"],
      "description": "Current obligation status"
    },
    "priority":    { "type": ["number", "null"], "minimum": 0, "maximum": 1, "description": "Obligation priority" },
    "description": { "type": "string", "description": "What investigative work is needed" },
    "due_cycle":   { "type": ["integer", "null"], "description": "Cycle by which this should be resolved" },
    "ttl_hours":   { "type": ["number", "null"], "description": "Time-to-live in hours (alternative to due_cycle)" },
    "created_at":  { "type": "string", "format": "date-time" },
    "due_at":      { "type": ["string", "null"], "format": "date-time" },
    "resolved_at": { "type": ["string", "null"], "format": "date-time" },
    "resolution_intervention_id": { "type": ["string", "null"], "description": "Intervention that resolved this obligation" },
    "resolution_type": {
      "type": ["string", "null"],
      "enum": ["answered", "declined", "deferred", "expired", null]
    }
  }
}
